<UserControl x:Class="XTodo.Views.TaskTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XTodo.ViewModels"
             xmlns:cv="clr-namespace:XTodo.Converters">

    <UserControl.Resources>
        <cv:BoolToTextDecorationConverter x:Key="BoolToStrikethrough"/>
        <cv:BoolToForegroundConverter x:Key="BoolToForeground"/>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <cv:BoolToSuccessForegroundConverter x:Key="BoolToSuccessForeground"/>

        <!-- 自定义勾选框 -->
        <Style x:Key="TaskCheckBox" TargetType="CheckBox">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CheckBorder" Width="16" Height="16"
                                Background="Transparent" BorderBrush="#A1887F"
                                BorderThickness="1.5" CornerRadius="0">
                            <Path x:Name="CheckMark"
                                  Data="M 2,8 L 6,12 L 14,4"
                                  Stroke="#81C784" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Visibility="Collapsed"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#81C784"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#FFF0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 悬浮按钮样式 -->
        <Style x:Key="HoverButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}"
                                CornerRadius="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#FFE082"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Border Grid.Row="0" Background="#FFF3E0" CornerRadius="0"
                Padding="8,6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋 " FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayTasks.Count, Mode=OneWay}"
                               FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#5D4037" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text=" 项任务"
                               FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#8D6E63" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="➕ 添加任务"
                        FontFamily="Microsoft YaHei" FontSize="12"
                        Background="#81C784" Foreground="White"
                        BorderThickness="0" Padding="10,4" Cursor="Hand"
                        Command="{Binding AddRootTaskCommand}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Background" Value="#81C784"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="AddBtnBorder" Background="{TemplateBinding Background}"
                                                CornerRadius="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="AddBtnBorder" Property="Background" Value="#66BB6A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- 任务列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DisplayTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Border x:Name="TaskRow" Background="Transparent" Padding="4,1" CornerRadius="0"
                                MouseEnter="TaskRow_MouseEnter" MouseLeave="TaskRow_MouseLeave">
                            <Grid Height="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 缩进 + 展开 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="{Binding IndentMargin, Mode=OneWay}">
                                    <Button Content="{Binding ExpandIcon, Mode=OneWay}"
                                            Width="18" Height="18" FontSize="9"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#A1887F" Cursor="Hand"
                                            Style="{StaticResource HoverButton}"
                                            Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                                            Command="{Binding ToggleExpandCommand}"/>
                                    <TextBlock Text=" " Width="18"
                                               Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}"/>
                                </StackPanel>

                                <!-- 勾选框 -->
                                <CheckBox Grid.Column="1" Style="{StaticResource TaskCheckBox}"
                                          IsChecked="{Binding IsCompleted, Mode=TwoWay}"/>

                                <!-- 任务内容 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="{Binding ActiveRootIcon, Mode=OneWay}"
                                            Width="20" Height="20" FontSize="12"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#FFB74D" Cursor="Hand"
                                            Style="{StaticResource HoverButton}"
                                            Visibility="{Binding IsRoot, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                                            Command="{Binding ToggleActiveRootCommand}"/>

                                    <Grid>
                                        <!-- 显示态 -->
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   FontFamily="Microsoft YaHei"
                                                   FontSize="{Binding NameFontSize, Mode=OneWay}"
                                                   FontWeight="{Binding NameFontWeight, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethrough}, Mode=OneWay}"
                                                   Foreground="{Binding IsCompleted, Converter={StaticResource BoolToForeground}, Mode=OneWay}"
                                                   ToolTip="双击编辑任务名称" MaxWidth="300"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}"
                                                   MouseLeftButtonDown="TaskName_MouseLeftButtonDown"/>
                                        <!-- 编辑态 -->
                                        <TextBox x:Name="EditBox"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Microsoft YaHei"
                                                 FontSize="{Binding NameFontSize, Mode=OneWay}"
                                                 FontWeight="{Binding NameFontWeight, Mode=OneWay}"
                                                 VerticalAlignment="Center" MinWidth="100" MaxWidth="300"
                                                 Padding="2,1,2,1"
                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                                                 Loaded="EditBox_Loaded" KeyDown="EditBox_KeyDown"
                                                 LostFocus="EditBox_LostFocus"/>
                                    </Grid>

                                    <Button Background="Transparent" BorderThickness="0"
                                            Foreground="#8D6E63" Cursor="Hand"
                                            ToolTip="{Binding TimeTooltip, Mode=OneWay}"
                                            Command="{Binding SetTimeCommand}"
                                            Style="{StaticResource HoverButton}"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <Button.Content>
                                            <TextBlock FontFamily="Microsoft YaHei" FontSize="11">
                                                <Run Text="⏱ "/><Run Text="{Binding TimeDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Button.Content>
                                    </Button>

                                    <TextBlock Text="{Binding ChildProgressBadge, Mode=OneWay}"
                                               FontFamily="Microsoft YaHei" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding AreAllChildrenCompleted, Converter={StaticResource BoolToSuccessForeground}, Mode=OneWay}"
                                               Margin="6,0,0,0"
                                               Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                                               ToolTip="子任务完成进度"/>

                                    <Button Width="20" Height="20" FontSize="11"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#8D6E63" Cursor="Hand"
                                            ToolTip="{Binding CriteriaTooltip, Mode=OneWay}"
                                            Command="{Binding EditCriteriaCommand}"
                                            Style="{StaticResource HoverButton}"
                                            Padding="0" Margin="4,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="📝" FontSize="10"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>

                                    <TextBlock Text="{Binding CriteriaSnippet, Mode=OneWay}"
                                               FontFamily="Microsoft YaHei" FontSize="11"
                                               VerticalAlignment="Center" Foreground="#8D6E63"
                                               Margin="4,0,0,0" MaxWidth="120"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CriteriaTooltip, Mode=OneWay}"
                                               Visibility="{Binding HasCriteria, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel x:Name="ActionButtons" Grid.Column="3"
                                            Orientation="Horizontal" VerticalAlignment="Center" Opacity="0">
                                    <Button Content="＋" Width="24" Height="24" FontSize="12"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#81C784" Cursor="Hand"
                                            Style="{StaticResource HoverButton}"
                                            ToolTip="添加子任务"
                                            Command="{Binding AddChildCommand}"
                                            Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>
                                    <Button Content="✕" Width="24" Height="24" FontSize="12"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#E57373" Cursor="Hand"
                                            Style="{StaticResource HoverButton}"
                                            ToolTip="删除任务"
                                            Command="{Binding DeleteCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
