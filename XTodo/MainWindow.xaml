<Window x:Class="XTodo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:XTodo.Views"
        xmlns:vm="clr-namespace:XTodo.ViewModels"
        xmlns:cv="clr-namespace:XTodo.Converters"
        mc:Ignorable="d"
        Title="XTodo"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing"
        x:Name="MainWin"
        Height="500" Width="640">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <cv:IsActiveCategoryConverter x:Key="IsActiveCategoryConverter"/>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 小图标按钮悬浮样式 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#FFE082"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 全局滚动条样式（极细条） -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root">
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{x:Null}"
                                                  Width="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{x:Null}"
                                                  Width="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#C0B8A8" Cursor="Hand" BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="4"/>
                                <Setter Property="MinWidth" Value="4"/>
                                <Setter TargetName="Root" Property="Width" Value="4"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4"/>
                                <Setter Property="MinHeight" Value="4"/>
                                <Setter TargetName="Root" Property="Height" Value="4"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder"
            Background="#FFF8E1"
            CornerRadius="0"
            BorderBrush="#D7CCC8"
            BorderThickness="1"
            MouseEnter="Border_MouseEnter"
            MouseLeave="Border_MouseLeave">
        <Border.Effect>
            <DropShadowEffect Color="#20000000"
                              BlurRadius="3"
                              ShadowDepth="1"
                              Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <!-- 收起态窄条 -->
            <Border x:Name="CollapsedBar"
                    Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVis}}"
                    Background="Transparent">
                <StackPanel Orientation="Horizontal" Height="30" Margin="14,0"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#5D4037" FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <Run Text="{Binding PendingCount, Mode=OneWay}"/><Run Text=" 项待办"/>
                    </TextBlock>
                    <TextBlock Text=" │ "
                               FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#D7CCC8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentRootTaskName, Mode=OneWay}"
                               FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#3E2723" VerticalAlignment="Center"
                               MaxWidth="260" TextTrimming="CharacterEllipsis" Margin="4,0"/>
                    <TextBlock FontFamily="Microsoft YaHei" FontSize="12"
                               Foreground="#8D6E63" VerticalAlignment="Center"
                               Visibility="{Binding HasCurrentRootTaskTime, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <Run Text="⏱ "/><Run Text="{Binding CurrentRootTaskTime, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 展开态面板 -->
            <Grid Margin="10"
                  Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="XTodo"
                               FontFamily="Microsoft YaHei" FontSize="11"
                               Foreground="#BDBDBD" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="⚙" Style="{StaticResource IconButton}"
                            Foreground="#BDBDBD" Click="Settings_Click" ToolTip="设置"/>
                    <Button Content="✕" Style="{StaticResource IconButton}"
                            Foreground="#8D6E63" Click="CloseButton_Click" ToolTip="隐藏到托盘"/>
                </StackPanel>

                <!-- Tab 栏 -->
                <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="0"
                        Padding="4,2" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="➕"
                                Width="28" Height="24" FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#81C784" Cursor="Hand" ToolTip="新建分类"
                                Command="{Binding AddCategoryCommand}" Margin="2,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="AddCatBorder"
                                            Background="{TemplateBinding Background}" CornerRadius="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="AddCatBorder" Property="Background" Value="#FFE082"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <ScrollViewer Grid.Column="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SwitchCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id, Mode=OneWay}"
                                                ToolTip="左键切换 · 双击重命名 · 右键删除">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="FontFamily" Value="Microsoft YaHei"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Foreground" Value="#8D6E63"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="0" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <EventSetter Event="MouseDoubleClick" Handler="Tab_DoubleClick"/>
                                                    <EventSetter Event="MouseRightButtonDown" Handler="Tab_RightClick"/>
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Tab_MouseDown"/>
                                                    <EventSetter Event="PreviewMouseMove" Handler="Tab_MouseMove"/>
                                                    <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Tab_MouseUp"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FFE082"/>
                                                        </Trigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource IsActiveCategoryConverter}">
                                                                    <Binding Path="Id" Mode="OneWay"/>
                                                                    <Binding Path="DataContext.CurrentCategory.Id"
                                                                             RelativeSource="{RelativeSource AncestorType=Window}" Mode="OneWay"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Background" Value="#FFECB3"/>
                                                            <Setter Property="Foreground" Value="#5D4037"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 任务树 -->
                <views:TaskTreeView Grid.Row="2" x:Name="TaskTree" DataContext="{Binding}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
